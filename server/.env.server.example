# DeepSeek API 配置
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 产出目录（服务器端写入 git repo 内的 output/，通过 git push 同步到 Mac）
OBSIDIAN_VAULT=/home/ubuntu/stock-review/output
OBSIDIAN_REVIEW_DIR=01-Projects/股票复盘
OBSIDIAN_TRACKING_DIR=01-Projects/股票跟踪

# 日志级别
LOG_LEVEL=INFO
